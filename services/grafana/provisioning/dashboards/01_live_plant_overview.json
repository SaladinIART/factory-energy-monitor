{
  "title": "Live Plant Overview",
  "uid": "live-plant-overview",
  "tags": ["factory", "live"],
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "type": "stat",
      "title": "Total Plant Load (kW)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "kwatt",
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 80 }
            ]
          }
        }
      },
      "targets": [{
        "rawSql": "SELECT NOW() AS time, SUM(real_power_w)/1000.0 AS value FROM meter_readings WHERE time > NOW() - INTERVAL '1 minute'",
        "format": "time_series"
      }]
    },
    {
      "type": "timeseries",
      "title": "Active Power per Zone (kW)",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "kwatt" }
      },
      "targets": [{
        "rawSql": "SELECT time_bucket('1 minute', time) AS time, zone_name, AVG(real_power_w)/1000.0 AS kw FROM meter_readings WHERE $__timeFilter(time) GROUP BY 1, 2 ORDER BY 1",
        "format": "time_series"
      }]
    },
    {
      "type": "gauge",
      "title": "Power Factor — Press Line A",
      "gridPos": { "x": 0, "y": 12, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "min": 0.7, "max": 1.0,
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 0.85 },
              { "color": "green", "value": 0.92 }
            ]
          }
        }
      },
      "targets": [{
        "rawSql": "SELECT NOW() AS time, AVG(power_factor) AS value FROM meter_readings WHERE meter_id = 'METER-01' AND time > NOW() - INTERVAL '2 minutes'",
        "format": "time_series"
      }]
    },
    {
      "type": "gauge",
      "title": "Power Factor — Press Line B",
      "gridPos": { "x": 6, "y": 12, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "min": 0.7, "max": 1.0,
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 0.85 },
              { "color": "green", "value": 0.92 }
            ]
          }
        }
      },
      "targets": [{
        "rawSql": "SELECT NOW() AS time, AVG(power_factor) AS value FROM meter_readings WHERE meter_id = 'METER-02' AND time > NOW() - INTERVAL '2 minutes'",
        "format": "time_series"
      }]
    },
    {
      "type": "gauge",
      "title": "Power Factor — CNC & Machining",
      "gridPos": { "x": 12, "y": 12, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "min": 0.7, "max": 1.0,
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 0.85 },
              { "color": "green", "value": 0.92 }
            ]
          }
        }
      },
      "targets": [{
        "rawSql": "SELECT NOW() AS time, AVG(power_factor) AS value FROM meter_readings WHERE meter_id = 'METER-03' AND time > NOW() - INTERVAL '2 minutes'",
        "format": "time_series"
      }]
    },
    {
      "type": "gauge",
      "title": "Power Factor — Assembly & HVAC",
      "gridPos": { "x": 18, "y": 12, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "min": 0.7, "max": 1.0,
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 0.85 },
              { "color": "green", "value": 0.92 }
            ]
          }
        }
      },
      "targets": [{
        "rawSql": "SELECT NOW() AS time, AVG(power_factor) AS value FROM meter_readings WHERE meter_id = 'METER-04' AND time > NOW() - INTERVAL '2 minutes'",
        "format": "time_series"
      }]
    }
  ],
  "schemaVersion": 36
}
