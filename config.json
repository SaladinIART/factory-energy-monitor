{
    "modbus": {
      "port": "/dev/ttyUSB0",
      "slave_address": 1,
      "baudrate": 19200,
      "bytesize": 8,
      "parity": "E",
      "stopbits": 1,
      "timeout": 1,
      "mode": "RTU"
    },
    "database": {
      "server": "YOUR_DB_SERVER_IP",
      "database": "YOUR_DB_NAME",
      "user": "YOUR_DB_USER",
      "password": "YOUR_DB_PASSWORD",
      "table_name": "dbo.Meter_Readings"
    },
    "logging": {
      "file": "rx380_logger.log",
      "level": "INFO"
    },
    "file_paths": {
      "csv_folder": "./logs"
    },
    "data_save_interval": {
      "minutes": 10
    }
  }
